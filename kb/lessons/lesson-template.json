{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kb/lessons/lesson-template.json",
  "title": "Lesson Template (Phase 0)",
  "type": "object",
  "required": [
    "id",
    "lessonTitle",
    "learningObjective",
    "explanation",
    "practiceExercise",
    "assessmentMethod"
  ],
  "properties": {
    "id": { "type": "string" },
    "lessonTitle": { "type": "string" },
    "learningObjective": { "type": "string" },

    "explanation": {
      "type": "object",
      "required": ["simple", "scholarGrounded"],
      "properties": {
        "simple": {
          "type": "string",
          "description": "Simple explanation intended for students. Must be derived from scholar-grounded content; it is not allowed to be invented."
        },
        "scholarGrounded": {
          "type": "object",
          "required": ["content", "scholarReferences"],
          "properties": {
            "content": {
              "type": "string",
              "description": "Stored scholar-grounded explanation text (may be a paraphrase/summary if approved by ingestion)."
            },
            "scholarReferences": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["workId", "referenceSpanId"],
                "properties": {
                  "workId": { "type": "string" },
                  "referenceSpanId": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },

    "scholarReference": {
      "type": "array",
      "description": "Optional legacy/duplicate list of scholar references for convenience.",
      "items": {
        "type": "object",
        "required": ["workId", "referenceSpanId"],
        "properties": {
          "workId": { "type": "string" },
          "referenceSpanId": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },

    "videoReference": {
      "type": "object",
      "properties": {
        "videoRefId": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["startMs", "endMs", "description"],
            "properties": {
              "startMs": { "type": "integer" },
              "endMs": { "type": "integer" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "audioExample": {
      "type": "object",
      "properties": {
        "audioRefId": { "type": "string" },
        "segments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["startMs", "endMs", "description"],
            "properties": {
              "startMs": { "type": "integer" },
              "endMs": { "type": "integer" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "practiceExercise": {
      "type": "object",
      "required": ["exerciseType", "prompt", "steps", "studentOutputFormat"],
      "properties": {
        "exerciseType": {
          "type": "string",
          "enum": ["pronunciation", "reading", "matching", "fill-gap"]
        },
        "prompt": { "type": "string" },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "studentOutputFormat": {
          "type": "string",
          "enum": ["recording", "text-entry", "upload"]
        }
      }
    },

    "assessmentMethod": {
      "type": "object",
      "required": ["methodType"],
      "properties": {
        "methodType": {
          "type": "string",
          "enum": ["rubric", "audio-check", "quiz"]
        },
        "rubricJson": { "type": "object" },
        "passCriteria": { "type": "object" },
        "evaluationNotes": { "type": "string" }
      }
    },

    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },

    "tags": { "type": "array", "items": { "type": "string" }, "default": [] },

    "governance": {
      "type": "object",
      "description": "Phase 0 fields for provenance enforcement.",
      "properties": {
        "requiresProvenance": { "type": "boolean", "default": true },
        "provenanceStatus": { "type": "string", "enum": ["missing", "partial", "complete"], "default": "missing" },
        "notes": { "type": "string" }
      }
    }
  }
}

